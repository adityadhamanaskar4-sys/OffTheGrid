{
  "name": "offthegrid-client-app",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "npm --prefix ../client-web run dev",
    "dev:main": "tsc -p tsconfig.electron.json --watch",
    "dev:electron": "wait-on tcp:5173 dist-electron/main.js && electron .",
    "dev": "concurrently -n renderer,main,electron -c green,magenta,blue \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm --prefix ../client-web run build && npm run build:electron",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.offthegrid.desktop",
    "productName": "OffTheGrid",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "../client-web/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../client-web/dist",
        "to": "client-web-dist"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
